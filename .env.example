# =============================================================================
# Copywriting Bot — environment configuration
# Copy to .env.local for local dev; populate via Vercel/Supabase dashboards
# in deployed environments. Never commit real values.
# =============================================================================

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_OPS_URL=http://localhost:3001
NODE_ENV=development

# --- Anthropic ---
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME
ANTHROPIC_MODEL_PLANNING=claude-opus-4-7
ANTHROPIC_MODEL_DEVELOPMENT=claude-sonnet-4-6
ANTHROPIC_MODEL_FAST=claude-haiku-4-5-20251001

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://REPLACE.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=REPLACE_ME
SUPABASE_SERVICE_ROLE_KEY=REPLACE_ME
SUPABASE_DB_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# --- Stripe (test mode for MVP) ---
STRIPE_SECRET_KEY=sk_test_REPLACE_ME
STRIPE_PUBLISHABLE_KEY=pk_test_REPLACE_ME
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME
STRIPE_PRICE_ID_FULL_REWRITE=price_REPLACE_ME

# --- Inngest ---
INNGEST_EVENT_KEY=REPLACE_ME
INNGEST_SIGNING_KEY=REPLACE_ME
INNGEST_DEV=1

# --- Postmark (transactional) ---
POSTMARK_SERVER_TOKEN=REPLACE_ME
POSTMARK_FROM_ADDRESS=hello@copywritingbot.com

# --- Smartlead (customer send infra) ---
SMARTLEAD_API_KEY=REPLACE_ME
SMARTLEAD_BASE_URL=https://server.smartlead.ai/api/v1

# --- Apollo (prospect enrichment for bot's outbound) ---
APOLLO_API_KEY=REPLACE_ME

# --- Observability ---
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
POSTHOG_SERVER_KEY=

# --- Operator ---
OPERATOR_EMAIL=tim@example.com
APPROVAL_GATES_DEFAULT_ON=true
